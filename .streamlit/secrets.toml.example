# Copy this file to .streamlit/secrets.toml and fill in real values.
# The real secrets.toml is gitignored.

ANTHROPIC_API_KEY = "sk-ant-your-key-here"
APP_ADMIN_TOKEN = "your-permanent-admin-token"

# --- Firebase (email/password auth + Firestore) ---
# Web API key from Firebase console → Project settings → General → Web API Key
[firebase]
web_api_key = "AIza-your-web-api-key"

# Paste the contents of your Firebase service-account JSON here. Get it
# from Firebase console → Project settings → Service accounts → Generate
# new private key. Replace literal newlines in private_key with \n.
[firebase.service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "firebase-adminsdk-...@your-project.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."

# --- Gmail SMTP (admin signup notifications) ---
# Use a Gmail "App password" — not your real account password.
# https://support.google.com/accounts/answer/185833
[smtp]
host = "smtp.gmail.com"
port = 587
user = "youraccount@gmail.com"
password = "your-16-char-app-password"
from_email = "youraccount@gmail.com"
to_email = "nileshvary@gmail.com"
